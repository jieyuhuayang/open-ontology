# Source MySQL (external, read-only for this workflow)
SOURCE_MYSQL_HOST=192.168.106.176
SOURCE_MYSQL_PORT=9001
SOURCE_MYSQL_DB=cofco_grease
SOURCE_MYSQL_USER=replace_me
SOURCE_MYSQL_PASSWORD=replace_me

# Local target MySQL container (sample clone)
MYSQL_IMAGE=mysql:8.0.37
TARGET_CONTAINER_NAME=openontology-mysql-sample
TARGET_VOLUME_NAME=openontology_mysql_sample_data
TARGET_MYSQL_PORT=13306
TARGET_MYSQL_DB=cofco_grease_mvp_sample
TARGET_MYSQL_USER=oo_sample
TARGET_MYSQL_PASSWORD=oo_sample
TARGET_MYSQL_ROOT_PASSWORD=oo_sample_root

# Row sample size per table
SAMPLE_LIMIT=100
